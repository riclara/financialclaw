{
  "name": "@riclara/financialclaw",
  "version": "0.3.0",
  "description": "Plugin OpenClaw para finanzas personales via Telegram",
  "type": "module",
  "main": "./dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/src/",
    "skills/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "postinstall": "npm rebuild better-sqlite3",
    "test": "tsx --test tests/**/*.test.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "version": "node scripts/sync-plugin-version.mjs && git add openclaw.plugin.json",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.8.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "openclaw": "^2026.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
